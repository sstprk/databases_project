@{
    ViewBag.Title = "Cabinly - Ana Sayfa"; // Title güncellendi
    Layout = "~/Views/Shared/_Layout.cshtml"; // Layout tanımlandı
}

<div class="text-center">
    
    @if (ViewBag.Username != null)
    {
        <div class="alert alert-success">
            <p>Merhaba, @ViewBag.Username!</p>
            <p>Rolünüz: @ViewBag.UserRole</p>
        </div>
        
        <div class="mt-3">
            <a href="@Url.Action("Logout", "Home")" class="btn btn-danger">Çıkış Yap</a>
        </div>
    }
</div>

<div class="search-container ">
    <h2>Rezervasyon Yapın</h2>
    @using (Html.BeginForm("Search", "Home", FormMethod.Get)) // Form helper eklendi (varsayılan olarak Home/Search)
    {
        <div class="search-form">
            <!-- Arama Kutusu -->
            @Html.TextBox("query", null, new { placeholder = "İstediğiniz şehri veya bölgeyi aratınız" }) 

            <!-- Kişi Sayısı -->
            @Html.DropDownList("guestCount", new SelectList(new List<SelectListItem> // Dropdown helper
            {
                new SelectListItem { Text = "1 Kişi", Value = "1" },
                new SelectListItem { Text = "2 Kişi", Value = "2" },
                new SelectListItem { Text = "3 Kişi", Value = "3" },
                new SelectListItem { Text = "4 Kişi", Value = "4" },
                new SelectListItem { Text = "5+ Kişi", Value = "5" }
            }, "Value", "Text"), new { @class = "form-control" }) 

            <!-- Gidiş ve Dönüş Tarihi -->
            <div class="dates-container">
                @Html.TextBox("checkInDate", null, new { type = "date", @class = "form-control" }) 
                @Html.TextBox("checkOutDate", null, new { type = "date", @class = "form-control" }) 
            </div>

            <!-- Arama Butonu -->
            <button class="search-btn" type="submit">Arama Yap</button> 
        </div>
    }
</div>

<div id="carouselExampleControls" class="carousel-container carousel slide" data-bs-ride="carousel"> @* data-ride Bootstrap 5'te data-bs-ride oldu *@
    <div class="carousel-inner">
      <div class="carousel-item">
        @* Resim yolları ~/ ile güncellendi *@
        <img src="~/img/photo-1628394029761-acc83a2a08a6.jpeg" class="d-block w-100" alt="...">
      </div>
      <div class="carousel-item active">
        <img src="~/img/photo-1628394029749-ea3dcce4caa6.jpeg" class="d-block w-100" alt="...">
      </div>
      <div class="carousel-item">
        <img src="~/img/photo-1601312044126-06d550c15beb.jpeg" class="d-block w-100" alt="...">
      </div>
    </div>
    @* Carousel kontrolleri Bootstrap 5 için güncellendi *@
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span> @* sr-only yerine visually-hidden *@
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Next</span> @* sr-only yerine visually-hidden *@
    </button>
  </div>