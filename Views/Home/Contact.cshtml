@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Hakkımızda";
}
    
    <div class="container-cs">
      <h1>Bizimle İletişime Geçin</h1>
      <p>Her türlü soru, öneri veya görüşleriniz için aşağıdaki formu doldurarak bize ulaşabilirsiniz.</p>
    
        <h4>📍 Adres</h4>
        <p>Turgutlu, 12345 Sokak No:12<br>Manisa / Türkiye</p>
    
        <h4>📞 Telefon</h4>
        <p><a href="tel:+905551112233">+90 555 111 22 33</a></p>
    
        <h4>✉️ E-posta</h4>
        <p><a href="mailto:info@cabinly">info@cabinly.com</a></p>
    
        <div class="social-icons">
          <a href="https://facebook.com/cabinly" target="_blank"><img class="icons" src="~/img/facebook.png" alt="facebook" style="width: 32px; height: 32px;"></a>
          <a href="https://instagram.com/cabinly" target="_blank"><img class="icons" src="~/img/instagram.png" alt="Instagram" style="width: 32px; height: 32px;"></a>
          <a href="https://twitter.com/cabinly" target="_blank"> <img class="icons" src="~/img/twitter.png" alt="X" style="width: 32px; height: 32px;"></a>
          
        </div>
  
      <form class="contact-form">
        <div class="form-group">
          <label for="name">Adınız</label>
          <input type="text" id="name" name="name" required />
        </div>
  
        <div class="form-group">
          <label for="email">E-posta</label>
          <input type="email" id="email" name="email" required />
        </div>
  
        <div class="form-group">
          <label for="subject">Konu</label>
          <input type="text" id="subject" name="subject" required />
        </div>
  
        <div class="form-group">
          <label for="message">Mesajınız</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
  
        <button class="login-btn" type="submit">Gönder</button>
      </form>
  
      
    </div>
