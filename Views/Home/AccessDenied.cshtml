@{
    ViewData["Title"] = "Erişim Reddedildi";
}

<div class="container text-center mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-danger">
                <div class="card-header bg-danger text-white">
                    <h1 class="display-4"><i class="fas fa-ban"></i> @ViewData["Title"]</h1>
                </div>
                <div class="card-body">
                    <h4 class="card-title">Bu sayfaya erişim yetkiniz bulunmamaktadır.</h4>
                    <p class="card-text lead">
                        Giriş yapmış olsanız bile, bu içeriği görüntülemek için gerekli rollere sahip değilsiniz.
                    </p>
                    <hr>
                    <p>
                        Bir hata olduğunu düşünüyorsanız, lütfen sistem yöneticisi ile iletişime geçin.
                    </p>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-primary mt-3">
                        <i class="fas fa-home"></i> Ana Sayfaya Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div> 