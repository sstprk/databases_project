@model IEnumerable<realCabinly.Models.Bookings>
@{
    ViewData["Title"] = "Rezervasyonlarım";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var paymentStatuses = ViewBag.PaymentStatuses as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container mt-5">
    <h2 class="text-center mb-4">@ViewData["Title"]</h2>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
    }

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>İlan ID</th>
                    <th>Başlangıç Tarihi</th>
                    <th>Bitiş Tarihi</th>
                    <th>Toplam Fiyat</th>
                    <th>Rezervasyon Durumu</th>
                    <th>Ödeme Durumu</th>
                    <th>Eylem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    var paymentStatus = paymentStatuses.ContainsKey(booking.id) ? paymentStatuses[booking.id] : "N/A";
                    <tr>
                        <td>@booking.listing_id</td>
                        <td>@booking.start_date.ToString("dd MMMM yyyy")</td>
                        <td>@booking.end_date.ToString("dd MMMM yyyy")</td>
                        <td>@booking.total_price.ToString("C")</td>
                        <td>@booking.status</td>
                        <td>@paymentStatus</td>
                        <td>
                            @if (booking.status.ToLower() == "confirmed" && paymentStatus.ToLower() == "pending")
                            {
                                <a asp-action="Payment" asp-controller="Home" asp-route-bookingId="@booking.id" class="btn btn-success btn-sm">Ödeme Yap</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (ViewBag.ErrorMessage == null)
    {
        <div class="alert alert-info text-center" role="alert">
            Henüz hiç rezervasyonunuz bulunmamaktadır.
        </div>
    }
</div> 