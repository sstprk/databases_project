@model IEnumerable<realCabinly.Models.PaymentViewModel>
@{
    ViewData["Title"] = "Ödeme Yönetimi";
}

<div class="container" style="margin-top: 30px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <div>
            <a asp-action="FinancialReports" class="btn btn-info">
                <i class="fas fa-chart-line"></i> Mali Raporlar
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h5>@Model.Count(p => p.Status.ToLower() == "completed")</h5>
                        <p>Tamamlanan Ödemeler</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body text-center">
                        <h5>@Model.Count(p => p.Status.ToLower() == "pending")</h5>
                        <p>Bekleyen Ödemeler</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center">
                        <h5>@Model.Count(p => p.Status.ToLower() == "failed")</h5>
                        <p>Başarısız Ödemeler</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h5>@Model.Where(p => p.Status.ToLower() == "completed").Sum(p => p.Amount).ToString("C")</h5>
                        <p>Toplam Gelir</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header text-white">
                <h4><i class="fas fa-credit-card"></i> Tüm Ödemeler</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Kullanıcı</th>
                                <th>İlan</th>
                                <th>Tutar</th>
                                <th>Ödeme Yöntemi</th>
                                <th>Durum</th>
                                <th>Tarih</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in Model.OrderByDescending(p => p.Paid_At))
                            {
                                <tr>
                                    <td>#@payment.Id</td>
                                    <td>
                                        <i class="fas fa-user text-primary"></i>
                                        @payment.UserName
                                    </td>
                                    <td>
                                        <i class="fas fa-home text-success"></i>
                                        @(payment.ListingTitle.Length > 30 ? payment.ListingTitle.Substring(0, 30) + "..." : payment.ListingTitle)
                                    </td>
                                    <td class="fw-bold">@payment.Amount.ToString("C")</td>
                                    <td>
                                        @{
                                            var methodIcon = payment.Payment_Method?.ToLower() switch
                                            {
                                                "credit_card" => "fas fa-credit-card",
                                                "paypal" => "fab fa-paypal",
                                                "bank_transfer" => "fas fa-university",
                                                _ => "fas fa-money-bill"
                                            };
                                        }
                                        <i class="@methodIcon"></i>
                                        @payment.Payment_Method
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = "bg-secondary";
                                            var statusIcon = "fas fa-clock";
                                            switch (payment.Status.ToLower())
                                            {
                                                case "completed": 
                                                    statusClass = "bg-success"; 
                                                    statusIcon = "fas fa-check-circle";
                                                    break;
                                                case "pending": 
                                                    statusClass = "bg-warning text-dark"; 
                                                    statusIcon = "fas fa-clock";
                                                    break;
                                                case "failed": 
                                                    statusClass = "bg-danger"; 
                                                    statusIcon = "fas fa-times-circle";
                                                    break;
                                            }
                                        }
                                        <span class="badge @statusClass">
                                            <i class="@statusIcon"></i>
                                            @payment.Status
                                        </span>
                                    </td>
                                    <td>@payment.Paid_At.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <button type="button" class="btn btn-sm btn-outline-info" 
                                                    title="Detayları Görüntüle" 
                                                    onclick="showPaymentDetails(@payment.Id, '@payment.UserName', '@payment.ListingTitle', '@payment.Amount', '@payment.Payment_Method', '@payment.Status', '@payment.Paid_At.ToString("dd MMM yyyy HH:mm")')">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                            @if (payment.Status.ToLower() == "pending")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-danger" 
                                                        title="Ödemeyi İptal Et" 
                                                        onclick="cancelPayment(@payment.Id)">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle fa-3x mb-3"></i>
            <h4>Henüz ödeme kaydı bulunmamaktadır.</h4>
            <p>Sistem kullanıcıları ödeme yaptıkça burada görüntülenecektir.</p>
        </div>
    }
</div>

<!-- Payment Details Modal -->
<div class="modal fade" id="paymentDetailsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ödeme Detayları</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="paymentDetailsBody">
                <!-- Payment details will be loaded here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

<script>
function showPaymentDetails(id, userName, listingTitle, amount, paymentMethod, status, paidAt) {
    const modalBody = document.getElementById('paymentDetailsBody');
    modalBody.innerHTML = `
        <div class="row">
            <div class="col-6"><strong>Ödeme ID:</strong></div>
            <div class="col-6">#${id}</div>
        </div>
        <hr>
        <div class="row">
            <div class="col-6"><strong>Kullanıcı:</strong></div>
            <div class="col-6">${userName}</div>
        </div>
        <hr>
        <div class="row">
            <div class="col-6"><strong>İlan:</strong></div>
            <div class="col-6">${listingTitle}</div>
        </div>
        <hr>
        <div class="row">
            <div class="col-6"><strong>Tutar:</strong></div>
            <div class="col-6">${amount}</div>
        </div>
        <hr>
        <div class="row">
            <div class="col-6"><strong>Ödeme Yöntemi:</strong></div>
            <div class="col-6">${paymentMethod}</div>
        </div>
        <hr>
        <div class="row">
            <div class="col-6"><strong>Durum:</strong></div>
            <div class="col-6">${status}</div>
        </div>
        <hr>
        <div class="row">
            <div class="col-6"><strong>Tarih:</strong></div>
            <div class="col-6">${paidAt}</div>
        </div>
    `;
    
    const modal = new bootstrap.Modal(document.getElementById('paymentDetailsModal'));
    modal.show();
}

function cancelPayment(paymentId) {
    if (confirm('Bu ödemeyi iptal etmek istediğinizden emin misiniz?')) {
        // Here you would typically make an AJAX call to cancel the payment
        alert('Ödeme iptal edildi. (Demo amaçlı mesaj)');
        location.reload();
    }
}
</script> 