@model realCabinly.Models.AdminListingDetailsViewModel
@{
    ViewData["Title"] = "İlan Detayları";
}

<div class="container my-5" >
    <div class="d-flex justify-content-between align-items-center mb-3" style="margin-top: 150px">
        <h3>@Model.Title</h3>
        <a asp-action="Listings" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> İlan Listesine Dön
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light py-3 text-white">
            <h4 class="mb-0"><i class="fas fa-info-circle text-primary me-2"></i>Genel Bilgiler</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <p><strong><i class="fas fa-file-alt me-2 text-muted"></i>Açıklama:</strong> @(string.IsNullOrWhiteSpace(Model.Description) ? "Bu ilan için bir açıklama girilmemiş." : Model.Description)</p>
                    <p><strong><i class="fas fa-map-marker-alt me-2 text-muted"></i>Konum:</strong> @Model.Location</p>
                    <p><strong><i class="fas fa-user me-2 text-muted"></i>İlan Sahibi:</strong> @Model.OwnerName</p>
                    <p><strong><i class="fas fa-dollar-sign me-2 text-muted"></i>Gecelik Fiyat:</strong> @Model.Price_Per_Night.ToString("C")</p>
                    <p>
                        <strong><i class="fas fa-check-circle me-2 text-muted"></i>Durum:</strong>
                        @if (Model.Is_Active)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Pasif</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-header bg-light py-3 text-white">
            <h4 class="mb-0"><i class="fas fa-images text-primary me-2"></i>İlan Fotoğrafları</h4>
        </div>
        <div class="card-body">
            @if (Model.Photos != null && Model.Photos.Any())
            {
                <div class="row">
                    @foreach (var photo in Model.Photos)
                    {
                        <div class="col-md-4 mb-3">
                            <img src="@photo.Image_Url" class="img-fluid rounded" alt="İlan Fotoğrafı" style="height: 200px; width: 100%; object-fit: cover;">
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">Bu ilana ait hiç fotoğraf bulunamadı.</div>
            }
        </div>
    </div>
</div> 