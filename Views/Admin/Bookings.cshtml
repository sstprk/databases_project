@model IEnumerable<realCabinly.Models.AdminBookingViewModel>
@{
    ViewData["Title"] = "Rezervasyon Yönetimi";
}

<div class="container" style="margin-top: 100px;">
    <h1>@ViewData["Title"]</h1>
    <p>Sistemdeki tüm rezervasyonları buradan yönetebilirsiniz.</p>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>İlan</th>
                            <th>Müşteri</th>
                            <th>Başlangıç Tarihi</th>
                            <th>Bitiş Tarihi</th>
                            <th>Toplam Fiyat</th>
                            <th>Durum</th>
                            <th class="text-end">Eylemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td>@booking.Id</td>
                                <td>@booking.ListingTitle</td>
                                <td>@booking.UserName</td>
                                <td>@booking.Start_Date.ToString("dd MMM yyyy")</td>
                                <td>@booking.End_Date.ToString("dd MMM yyyy")</td>
                                <td>@booking.Total_Price.ToString("C")</td>
                                <td>
                                    @{
                                        var statusClass = "bg-secondary";
                                        switch (booking.Status.ToLower())
                                        {
                                            case "confirmed": statusClass = "bg-success"; break;
                                            case "pending": statusClass = "bg-warning text-dark"; break;
                                            case "cancelled": statusClass = "bg-danger"; break;
                                        }
                                    }
                                    <span class="badge @statusClass">@booking.Status</span>
                                </td>
                                <td class="text-end">
                                    @if (booking.Status.ToLower() != "cancelled")
                                    {
                                        <form asp-action="CancelBooking" asp-route-id="@booking.Id" method="post" class="d-inline" onsubmit="return confirm('Bu rezervasyonu iptal etmek istediğinizden emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-warning btn-sm">İptal Et</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div> 