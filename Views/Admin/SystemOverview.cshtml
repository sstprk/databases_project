@model realCabinly.Models.SystemOverviewViewModel
@{
    ViewData["Title"] = "Sistem Durumu";
}

<div class="container" style="margin-top: 30px;">
    <h1>@ViewData["Title"]</h1>
    <p>Sisteminizin genel durumu ve performans metrikleri</p>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-gradient-primary text-black">
                <div class="card-body text-center">
                    <i class="fas fa-home fa-3x mb-3"></i>
                    <h3>@Model.TotalListings</h3>
                    <p>Toplam İlan</p>
                    <small>@Model.ActiveListings aktif</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-gradient-success text-black">
                <div class="card-body text-center">
                    <i class="fas fa-calendar-check fa-3x mb-3"></i>
                    <h3>@Model.TotalBookings</h3>
                    <p>Toplam Rezervasyon</p>
                    <small>@Model.ConfirmedBookings onaylandı</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-gradient-info text-black">
                <div class="card-body text-center">
                    <i class="fas fa-dollar-sign fa-3x mb-3"></i>
                    <h3>@Model.TotalRevenue.ToString("C")</h3>
                    <p>Toplam Gelir</p>
                    <small>@Model.MonthlyRevenue.ToString("C") bu ay</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header text-white">
                    <h5><i class="fas fa-chart-bar"></i> Rezervasyon Durumları</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <h6 class="text-warning">Bekleyen</h6>
                            <h4 class="text-warning">@Model.PendingBookings</h4>
                        </div>
                        <div class="col-4">
                            <h6 class="text-success">Onaylanan</h6>
                            <h4 class="text-success">@Model.ConfirmedBookings</h4>
                        </div>
                        <div class="col-4">
                            <h6 class="text-danger">İptal Edilen</h6>
                            <h4 class="text-danger">@Model.CancelledBookings</h4>
                        </div>
                    </div>
                    
                    <hr />
                    
                    @if (Model.TotalBookings > 0)
                    {
                        var confirmedRate = (Model.ConfirmedBookings * 100.0 / Model.TotalBookings);
                        var cancelledRate = (Model.CancelledBookings * 100.0 / Model.TotalBookings);
                        
                        <div class="mb-3">
                            <p class="mb-1">Onaylanma Oranı: %@confirmedRate.ToString("0.1")</p>
                            <div class="progress">
                                <div class="progress-bar bg-success" style="width: @confirmedRate%"></div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <p class="mb-1">İptal Oranı: %@cancelledRate.ToString("0.1")</p>
                            <div class="progress">
                                <div class="progress-bar bg-danger" style="width: @cancelledRate%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card">
                <div class="card-header text-white">
                    <h5><i class="fas fa-list"></i> İlan Durumları</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center mb-3">
                        <div class="col-6">
                            <h6 class="text-primary">Toplam İlan</h6>
                            <h4 class="text-primary">@Model.TotalListings</h4>
                        </div>
                        <div class="col-6">
                            <h6 class="text-success">Aktif İlan</h6>
                            <h4 class="text-success">@Model.ActiveListings</h4>
                        </div>
                    </div>
                    
                    <hr />
                    
                    @if (Model.TotalListings > 0)
                    {
                        var activeRate = (Model.ActiveListings * 100.0 / Model.TotalListings);
                        var inactiveCount = Model.TotalListings - Model.ActiveListings;
                        
                        <div class="mb-3">
                            <p class="mb-1">Aktif İlan Oranı: %@activeRate.ToString("0.1")</p>
                            <div class="progress">
                                <div class="progress-bar bg-success" style="width: @activeRate%"></div>
                            </div>
                        </div>
                        
                        <div class="alert alert-info">
                            <small><i class="fas fa-info-circle"></i> @inactiveCount ilan pasif durumda</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header text-white">
            <h5><i class="fas fa-tachometer-alt"></i> Sistem Performansı</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 text-center">
                    <div class="border-end">
                        <h5 class="text-success">@((Model.TotalListings > 0 ? Model.ActiveListings * 100.0 / Model.TotalListings : 0).ToString("0"))%</h5>
                        <p class="text-muted">İlan Aktiflik Oranı</p>
                    </div>
                </div>
                <div class="col-md-3 text-center">
                    <div class="border-end">
                        <h5 class="text-info">@((Model.TotalBookings > 0 ? Model.ConfirmedBookings * 100.0 / Model.TotalBookings : 0).ToString("0"))%</h5>
                        <p class="text-muted">Rezervasyon Başarı Oranı</p>
                    </div>
                </div>
                <div class="col-md-3 text-center">
                    <div class="border-end">
                        <h5 class="text-warning">@Model.MonthlyRevenue.ToString("C")</h5>
                        <p class="text-muted">Bu Ay Gelir</p>
                    </div>
                </div>
                <div class="col-md-3 text-center">
                    <h5 class="text-primary">@Model.PendingBookings</h5>
                    <p class="text-muted">Bekleyen İşlemler</p>
                </div>
            </div>
            
            <hr />
            
            <div class="alert alert-success">
                <h6><i class="fas fa-check-circle"></i> Sistem Durumu: Sağlıklı</h6>
                <p class="mb-0">Tüm servisler düzgün çalışıyor. Son güncelleme: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</p>
            </div>
        </div>
    </div>
</div> 