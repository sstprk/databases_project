@model realCabinly.Models.AdminLoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Girişi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 2.5rem;
            border: none;
            border-radius: 1rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            background-color: #fff;
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-header h2 {
            font-weight: 700;
            color: #333;
        }
        
        .login-header p {
            color: #6c757d;
        }

        .form-control {
            height: 50px;
            border-radius: 0.5rem;
        }

        .btn-primary {
            height: 50px;
            font-weight: 600;
            border-radius: 0.5rem;
        }

        .form-check-label {
             color: #6c757d;
        }
        
        .divider {
            text-align: center;
            margin: 1.5rem 0;
            border-bottom: 1px solid #dee2e6;
            line-height: 0.1em;
        }
        
        .divider span {
            background: #fff;
            padding: 0 10px;
            color: #6c757d;
        }

    </style>
</head>
<body>

    <div class="login-card">
        <div class="login-header">
            <i class="fas fa-user-shield fa-3x text-primary mb-3"></i>
            <h2>Yönetici Paneli</h2>
            <p>Lütfen devam etmek için giriş yapın</p>
        </div>

        <form asp-action="Index" method="post">
            @Html.AntiForgeryToken()
            
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">E-posta Adresi</label>
                <input asp-for="Email" class="form-control" placeholder="admin@example.com" required>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" class="form-control" placeholder="********" required>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="rememberMe">
                    <label class="form-check-label" for="rememberMe">
                        Beni Hatırla
                    </label>
                </div>
                <a href="#" class="small">Şifremi Unuttum</a>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-primary">Giriş Yap</button>
            </div>
            
            <div class="divider my-4"><span>Veya</span></div>

            <div class="d-grid">
                 <a href="/" class="btn btn-outline-secondary">Ana Sayfaya Dön</a>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 