@model IEnumerable<realCabinly.Models.AdminListingViewModel>
@{
    ViewData["Title"] = "İlan Yönetimi";
}

<div class="container" style="margin-top: 30px;">
    <h1>@ViewData["Title"]</h1>
    <p>Sistemdeki tüm ilanları buradan yönetebilirsiniz.</p>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Başlık</th>
                            <th>Konum</th>
                            <th>İlan Sahibi</th>
                            <th>Gecelik Fiyat</th>
                            <th>Durum</th>
                            <th class="text-end">Eylemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var listing in Model)
                        {
                            <tr>
                                <td>@listing.Id</td>
                                <td>@listing.Title</td>
                                <td>@listing.Location</td>
                                <td>@listing.OwnerName</td>
                                <td>@listing.Price_Per_Night.ToString("C")</td>
                                <td>
                                    @if (listing.Is_Active)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Pasif</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="ListingDetails" asp-route-id="@listing.Id" class="btn btn-info btn-sm">İncele</a>
                                    <form asp-action="DeleteListing" asp-route-id="@listing.Id" method="post" class="d-inline" onsubmit="return confirm('Bu ilanı ve ilişkili tüm verileri (rezervasyonlar, yorumlar) silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div> 