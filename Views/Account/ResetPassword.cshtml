@{
    ViewData["Title"] = "Şifre Sıfırlama";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-container">
    <h2>Şifre Sıfırlama</h2>
    <form method="post" asp-action="ResetPassword" asp-controller="Account">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" name="email" value="@ViewBag.Email">
        <input type="password" name="newPassword" class="form-control" placeholder="Yeni Şifre" required>
        <input type="password" name="confirmPassword" class="form-control" placeholder="Yeni Şifre (Tekrar)" required>
        <button type="submit" class="btn-login">Şifreyi Güncelle</button>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
} 