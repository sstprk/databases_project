@{
    ViewData["Title"] = "İletişim";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<div class="container-fluid mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">İletişime Geçin</h2>
                    <p class="text-center text-muted mb-4">Sorularınız, önerileriniz veya geri bildirimleriniz için bize ulaşın.</p>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post" asp-action="Contact" asp-controller="Home">
                        @Html.AntiForgeryToken()
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="name" class="form-label">Adınız Soyadınız</label>
                                <input type="text" class="form-control" id="name" name="name" placeholder="Adınız Soyadınız" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="email" class="form-label">E-posta Adresiniz</label>
                                <input type="email" class="form-control" id="email" name="email" placeholder="ornek@email.com" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="subject" class="form-label">Konu</label>
                            <input type="text" class="form-control" id="subject" name="subject" placeholder="Mesajınızın konusu" required>
                        </div>

                        <div class="mb-4">
                            <label for="message" class="form-label">Mesajınız</label>
                            <textarea class="form-control" id="message" name="message" rows="5" placeholder="Mesajınızı buraya yazın..." required></textarea>
                        </div>

                        <div class="d-flex justify-content-center">
                            <button type="submit" class="login-btn">Gönder</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- İletişim Bilgileri -->
            <div class="row mt-5">
                <div class="col-md-4 text-center mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-geo-alt-fill fs-1 text-primary mb-3"></i>
                            <h5 class="card-title">Adres</h5>
                            <p class="card-text text-muted">İstanbul, Türkiye</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-envelope-fill fs-1 text-primary mb-3"></i>
                            <h5 class="card-title">E-posta</h5>
                            <p class="card-text text-muted">info@realcabinly.com</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-telephone-fill fs-1 text-primary mb-3"></i>
                            <h5 class="card-title">Telefon</h5>
                            <p class="card-text text-muted">+90 (212) 123 45 67</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Harita -->
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-body p-0">
                            <iframe 
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d385398.5897809314!2d28.731994399999998!3d41.0049823!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14caa7040068086b%3A0xe1ccfe98bc01b0d0!2zxLBzdGFuYnVs!5e0!3m2!1str!2str!4v1647881234567!5m2!1str!2str" 
                                width="100%" 
                                height="400" 
                                style="border:0;" 
                                allowfullscreen="" 
                                loading="lazy">
                            </iframe>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}
