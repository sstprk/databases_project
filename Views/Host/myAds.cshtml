@model List<realCabinly.Controllers.Ilan>
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Host Page";
}

<!-- Bootstrap Icons -->
@section Scripts {
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    />
}

<div class="custom-container">
    <div class="row">
        <!-- Sol Menü -->
        <div class="col-md-3 sidebarS">
            <button class="btn-login" onclick="window.location.href='@Url.Action("myAds", "Host")'">İlanlarım</button>
            <button class="btn-login" onclick="window.location.href='@Url.Action("activeReservations", "Host")'">Aktif Rezervasyonlarım</button>
            <button class="btn-login" onclick="window.location.href='@Url.Action("reservationHistory", "Host")'">Geçmiş Rezervasyonlarım</button>
            <button class="btn-login" onclick="window.location.href='@Url.Action("newAd", "Host")'">Yeni İlan Ver</button>
            <button class="btn-login" onclick="window.location.href='@Url.Action("settings", "Host")'">Ayarlar</button>
            <button class="btn-login" id="btn-quit" onclick="window.location.href='@Url.Action("Logout", "Account")'">Çıkış Yap</button>
        </div>

        <!-- Sağ İçerik Alanı -->
        <div class="col-md-9 content-areaS" id="icerik">
            <div class="container mt-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>İlanlarım</h2>
                    <a asp-action="newAd" asp-controller="Host" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Yeni İlan Ekle
                    </a>
                </div>

                @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.ErrorMessage
                    </div>
                }
                else if (Model == null || !Model.Any())
                {
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle-fill"></i> Henüz yayınlanmış aktif bir ilanınız bulunmamaktadır. Yukarıdaki butondan yeni bir ilan ekleyebilirsiniz.
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column align-items-center gap-4">
                        @foreach (var ilan in Model)
                        {
                            string imagePath = ilan.CoverImageUrl;
                            if (string.IsNullOrEmpty(imagePath))
                            {
                                imagePath = "/images/default-ad-image.png";
                            }
                            else if (!imagePath.StartsWith("/") && !imagePath.StartsWith("~/"))
                            {
                                imagePath = "/" + imagePath;
                            }

                            <div class="card mb-3 w-100" style="max-width: 800px;">
                                <div class="row g-0 align-items-center">
                                    <div class="col-md-4">
                                        <img
                                            src="@Url.Content("~" + imagePath)"
                                            class="img-fluid rounded-start"
                                            alt="@ilan.Title"
                                            style="object-fit: cover; width: 100%; height: 200px;"
                                            onerror="this.onerror=null; this.src='@Url.Content("~/images/default-ad-image.png")';"
                                        />
                                    </div>
                                    <div class="col-md-8">
                                        <div class="card-body d-flex flex-column">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h5 class="card-title mb-0">@ilan.Title</h5>
                                                <span class="badge bg-success fs-6">
                                                    @ilan.PricePerNight.ToString("C", new System.Globalization.CultureInfo("tr-TR")) / gece
                                                </span>
                                            </div>

                                            <p class="card-text flex-grow-1">
                                                @Html.Raw(string.IsNullOrWhiteSpace(ilan.Description)
                                                    ? "Açıklama eklenmemiş."
                                                    : (ilan.Description.Length > 100
                                                        ? ilan.Description.Substring(0, 100) + "..."
                                                        : ilan.Description))
                                            </p>

                                            <p class="card-text">
                                                <small class="text-muted">Yayın Tarihi: @ilan.CreatedAt.ToString("dd MMMM yyyy, HH:mm")</small>
                                            </p>

                                            <div class="mt-3 d-flex justify-content-end gap-2">
                                                <form asp-action="DeleteAdConfirmed" asp-controller="Host" method="post" class="delete-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@ilan.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Sil">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>

                                                <a asp-action="EditAd" asp-controller="Host" asp-route-id="@ilan.Id" class="btn btn-outline-secondary btn-sm" title="Düzenle">
                                                    <i class="bi bi-pencil"></i>
                                                </a>

                                                <button class="btn btn-outline-warning btn-sm" title="Görünürlükten Kaldır" disabled>
                                                    <i class="bi bi-eye-slash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Silme işlemi için JS -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.delete-form').forEach(form => {
            form.addEventListener('submit', function (event) {
                event.preventDefault();
                if (confirm('Bu ilanı silmek istediğinizden emin misiniz?')) {
                    const button = form.querySelector('button[type="submit"]');
                    button.disabled = true;
                    const originalHtml = button.innerHTML;
                    button.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Siliniyor...';

                    fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form)
                    }).then(response => {
                        if (response.ok) {
                            form.closest('.card').remove();
                        } else {
                            alert('İlan silinirken bir hata oluştu.');
                            button.disabled = false;
                            button.innerHTML = originalHtml;
                        }
                    }).catch(error => {
                        console.error('Silme işlemi sırasında bir hata oluştu:', error);
                        alert('İlan silinirken bir hata oluştu.');
                        button.disabled = false;
                        button.innerHTML = originalHtml;
                    });
                }
            });
        });
    });
</script>
