@model List<realCabinly.Controllers.Ilan> 
@* Eğer Ilan sınıfını Models klasörüne taşıdıysanız ve namespace'i realCabinly.Models ise: *@
@* @model List<realCabinly.Models.Ilan> *@
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "İlanlarım";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <a asp-action="newAd" asp-controller="Host" class="btn btn-primary">
            <i class="fas fa-plus-circle"></i> Yeni İlan Ekle
        </a>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
    {
        <div class="alert alert-danger" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @ViewBag.ErrorMessage
        </div>
    }
    else if (Model == null || !Model.Any()) // Model'in null olma ihtimalini de ekleyelim
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i> Henüz yayınlanmış aktif bir ilanınız bulunmamaktadır. Yukarıdaki butondan yeni bir ilan ekleyebilirsiniz.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var ilan in Model)
            {
                string imagePath = ilan.CoverImageUrl;
                if (string.IsNullOrEmpty(imagePath)) // Eğer null veya boşsa varsayılanı ata
                {
                    imagePath = "/images/default-ad-image.png";
                }
                else if (!imagePath.StartsWith("/")) // Eğer / ile başlamıyorsa başına / ekle
                {
                    imagePath = "/" + imagePath;
                }

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@Url.Content("~" + imagePath)" class="card-img-top" alt="@ilan.Title" style="height: 220px; object-fit: cover;" 
                             onerror="this.onerror=null; this.src='@Url.Content("~/images/default-ad-image.png")';">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@ilan.Title</h5>
                            <p class="card-text text-muted"><i class="fas fa-map-marker-alt"></i> @ilan.Location</p>
                            <p class="card-text flex-grow-1">@Html.Raw(ilan.Description?.Length > 100 ? ilan.Description.Substring(0, 100) + "..." : ilan.Description)</p>
                            <div class="mt-auto">
                                <p class="card-text"><strong>@ilan.PricePerNight.ToString("C", new System.Globalization.CultureInfo("tr-TR")) / gece</strong></p>
                                <p class="card-text"><small class="text-muted">Yayın Tarihi: @ilan.CreatedAt.ToString("dd MMMM yyyy, HH:mm")</small></p>
                                
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    @* <a href="#" class="btn btn-sm btn-outline-primary">Detayları Gör</a> *@ 
                                    <a asp-action="EditAd" asp-controller="Host" asp-route-id="@ilan.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="fas fa-edit"></i> Düzenle
                                    </a>
                                    @* İleride eklenebilecek "Sil" butonu için yer tutucu
                                    <a href="#" class="btn btn-sm btn-outline-danger ms-1">
                                        <i class="fas fa-trash"></i> Sil
                                    </a> 
                                    *@
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Font Awesome ikonları için (eğer Layout sayfanızda yoksa) eklenebilir: *@
@* 
@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
}
*@

