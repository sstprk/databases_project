@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Host Page";
}



<div class="custom-container">
    <div class="row">
      <!-- Sol Menü -->
      <div class="col-md-3 sidebarS">
        <button class="btn-login" onclick="window.location.href='@Url.Action("myAds", "Host")'">İlanlarım</button>
        <button class="btn-login" onclick="window.location.href='@Url.Action("activeReservations", "Host")'">Aktif Rezervasyonlarım</button>
        <button class="btn-login" onclick="window.location.href='@Url.Action("reservationHistory", "Host")'">Geçmiş Rezervasyonlarım</button>
        <button class="btn-login" onclick="window.location.href='@Url.Action("newAd", "Host")'">Yeni İlan Ver</button>
        <button class="btn-login" onclick="window.location.href='@Url.Action("settings", "Host")'">Ayarlar</button>
        <button class="btn-login" id="btn-quit" onclick="window.location.href='@Url.Action("Logout", "Account")'">Çıkış Yap</button>

      </div>


      <!-- Sağ İçerik Alanı -->
      <div class="col-md-9 content-areaS" id="icerik">
        
}

<div class="card mb-3" style="max-width: 800px;">
  <div class="row g-0 align-items-center">
    <div class="col-md-4">
      <img
        src="https://via.placeholder.com/300x200"
        class="img-fluid rounded-start"
        alt="ilan görseli"
      />
    </div>
    <div class="col-md-8">
      <div class="card-body d-flex flex-column">
        
        <!-- Başlık + Fiyat -->
        <div class="d-flex justify-content-between align-items-start mb-2">
          <h5 class="card-title mb-0">Cozy Cabin Retreat</h5>
          <span class="badge bg-success fs-6">$120/night</span>
        </div>
        
        <!-- Açıklama -->
        <p class="card-text flex-grow-1">
          A serene cabin nestled in the woods, perfect for a weekend getaway.
        </p>
        
        <!-- Güncelleme Zamanı -->
        <p class="card-text">
          <small class="text-muted">Last updated 3 mins ago</small>
        </p>
        
        <!-- İptal Et Butonu -->
        <div class="mt-3 d-flex justify-content-end">
          <button class="btn-login  ">İptal Et</button>
        </div>
        
      </div>
    </div>
  </div>
</div>


      </div>
    </div>
  </div>