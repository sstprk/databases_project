@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Ana layout'u kullanıyoruz
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-12 col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-3">
                    <h2 class="text-center mb-0"><i class="fas fa-user-plus me-2"></i>Yeni Hesap Oluştur</h2>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Register" asp-controller="Account" method="post">
                        @* CSRF token için ValidateAntiForgeryToken attribute'u controller'da olduğundan burada @Html.AntiForgeryToken() gerekmez *@
                        
                        <div asp-validation-summary="All" class="text-danger mb-3"></div> @* Tüm hataları göster *@

                        <div class="mb-3">
                            <label for="name" class="form-label fw-semibold">Adınız</label>
                            <input type="text" name="name" class="form-control form-control-lg" id="name" placeholder="Adınızı girin" required>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">E-posta Adresiniz</label>
                            <input type="email" name="email" class="form-control form-control-lg" id="email" placeholder="ornek@mail.com" required>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label fw-semibold">Şifreniz</label>
                            <input type="password" name="password" class="form-control form-control-lg" id="password" placeholder="••••••••" required>
                        </div>

                        <div class="mb-4">
                            <label for="confirmPassword" class="form-label fw-semibold">Şifreniz (Tekrar)</label>
                            <input type="password" name="confirmPassword" class="form-control form-control-lg" id="confirmPassword" placeholder="••••••••" required>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-check-circle me-2"></i>Kayıt Ol</button>
                        </div>
                    </form>
                    <hr>
                    <div class="text-center">
                        <p class="mb-0">Zaten bir hesabınız var mı? <a asp-action="Login" asp-controller="Account">Giriş Yapın</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>