@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "My Ads";
}

<div class="card mb-3" style="max-width: 800px;">
  <div class="row g-0 align-items-center">
    <div class="col-md-4">
      <img
        src="https://via.placeholder.com/300x200"
        class="img-fluid rounded-start"
        alt="ilan görseli"
      />
    </div>
    <div class="col-md-8">
      <div class="card-body d-flex flex-column">
        
        <!-- Başlık + Fiyat -->
        <div class="d-flex justify-content-between align-items-start mb-2">
          <h5 class="card-title mb-0">Cozy Cabin Retreat</h5>
          <span class="badge bg-success fs-6">$120/night</span>
        </div>
        
        <!-- Açıklama -->
        <p class="card-text flex-grow-1">
          A serene cabin nestled in the woods, perfect for a weekend getaway.  
        </p>
        
        <!-- Güncelleme Zamanı -->
        <p class="card-text">
          <small class="text-muted">Last updated 3 mins ago</small>
        </p>
        
        <!-- İşlem Butonları -->
        <div class="mt-3 d-flex justify-content-end gap-2">
          <!-- Sil -->
          <button
            class="btn btn-outline-danger btn-sm"
            title="Sil"
          >
            <i class="bi bi-trash"></i>
          </button>
          
          <!-- Düzenle -->
          <button
            class="btn btn-outline-secondary btn-sm"
            title="Düzenle"
          >
            <i class="bi bi-pencil"></i>
          </button>
          
          <!-- Görünürlükten Kaldır -->
          <button
            class="btn btn-outline-warning btn-sm"
            title="Görünürlükten Kaldır"
          >
            <i class="bi bi-eye-slash"></i>
          </button>
        </div>
        
      </div>
    </div>
  </div>
</div>

